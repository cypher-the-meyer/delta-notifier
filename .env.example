# ─────────────────────────────────────────────────────────────────────────────
# Delta Notifier — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Path to your Service Account JSON key (downloaded from Google Cloud Console)
# IAM & Admin → Service Accounts → your account → Keys → Add Key → JSON
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials.json

# ── Google API Key ────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → Create Credentials → API Key
# Restrict it to: Drive API, Cloud Storage API, Pub/Sub API
GOOGLE_API_KEY=YOUR_API_KEY_HERE

# ── Google Chat ───────────────────────────────────────────────────────────────
# Google Chat space → Manage webhooks → Copy URL
# The key= param in the webhook URL should match GOOGLE_API_KEY
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXXXXX/messages?key=YOUR_API_KEY_HERE

# ── Google Drive ──────────────────────────────────────────────────────────────
# The ID of the Drive folder to watch.
# Open the folder in Drive → copy the last segment of the URL
# e.g. https://drive.google.com/drive/folders/1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs78
DRIVE_FOLDER_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs78

# How often (in seconds) to poll Drive for changes  (min recommended: 15)
DRIVE_POLL_INTERVAL_SEC=30

# ── Google Cloud Storage + Pub/Sub ────────────────────────────────────────────
# Your GCP project ID  (Google Cloud Console → home dashboard → Project ID)
GCS_PUBSUB_PROJECT=my-gcp-project-id

# GCS bucket that holds your payload files
GCS_BUCKET_NAME=delta-notifier-payloads

# Pub/Sub subscription name  (Pub/Sub → Subscriptions → your subscription)
GCS_PUBSUB_SUBSCRIPTION=delta-notifier-sub

# ── Local paths ───────────────────────────────────────────────────────────────
# Where downloaded payload files are cached locally
LOCAL_PAYLOADS_DIR=./payloads
